generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Waitlist {
  id    String @id @default(auto()) @map("_id") @db.ObjectId
  email String @unique
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.String
  access_token      String? @db.String
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.String
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id              String     @id @default(auto()) @map("_id") @db.ObjectId
  name            String?
  email           String?    @unique
  phone           String? // Store in E.164 format (e.g., "+919876543210")
  whatsappEnabled Boolean    @default(false)
  emailVerified   DateTime?
  image           String?
  wakatimeApiKey  String?
  githubApiKey    String?
  linkedinApiKey  String?
  twitterApiKey   String?
  accounts        Account[]
  sessions        Session[]
  // Add your app-specific fields here
  habits          Habit[]
  tasks           Task[]
  todos           Todo[]
  wakaTimeStats   WakaTime[]
  workoutPlans    WorkoutPlan[]

  height      Float?
  weight      Float?
  fitnessGoal String? // "Bulking", "Cutting", "Strength"
  experience  String? // "Beginner", "Intermediate"
}

model Habit {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  name        String
  description String?
  category    String?
  frequency   String   @default("daily") // daily, weekly
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs HabitLog[]
}

model HabitLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  habitId   String   @db.ObjectId
  date      DateTime
  completed Boolean  @default(true)
  createdAt DateTime @default(now())

  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)
}

model Task {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  title       String
  description String?
  category    String? // Code, Fitness, Freelance, Growth, etc.
  startDate   DateTime
  endDate     DateTime
  status      String   @default("pending") // pending, in-progress, completed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Todo {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  userId           String    @db.ObjectId
  task             String
  category         String?
  reminderTime     DateTime?
  extraTime        Int?
  whatsappNotified Boolean   @default(false)
  completed        Boolean   @default(false)
  completedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WakaTime {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @db.ObjectId
  date       DateTime
  totalTime  String
  projects   Json
  languages  Json
  categories Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model SystemConfig {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model WorkoutPlan {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @db.ObjectId
  goal       String // e.g., "Full Body Hypertrophy"
  weekNumber Int // To track Week 1, Week 2, etc.
  startDate  DateTime
  endDate    DateTime
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  workouts Workout[]
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Workout {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  planId      String    @db.ObjectId
  dayOfWeek   String // "Monday"
  focus       String // "Chest + Triceps"
  isCompleted Boolean   @default(false)
  completedAt DateTime?

  exercises   WorkoutExercise[]
  workoutPlan WorkoutPlan       @relation(fields: [planId], references: [id], onDelete: Cascade)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model WorkoutExercise {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  workoutId   String   @db.ObjectId
  exerciseId   String
  name        String   // e.g., "Bench Press"
  sets        Int
  reps        Int
  weight      Float?   // The weight assigned by the AI
  gifUrl      String?  // From ExerciseDB
  notes       String?  // Form tips from the Researcher Agent
  completedSets Int    @default(0)
  
  workout     Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
}