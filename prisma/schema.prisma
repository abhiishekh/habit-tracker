generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Waitlist {
  id    String @id @default(auto()) @map("_id") @db.ObjectId
  email String @unique
}

model Account {
  id                String  @id @default(auto()) @map("_id") @db.ObjectId
  userId            String  @db.ObjectId
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.String
  access_token      String? @db.String
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.String
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  sessionToken String   @unique
  userId       String   @db.ObjectId
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id              String     @id @default(auto()) @map("_id") @db.ObjectId
  name            String?
  email           String?    @unique
  phone           String? // Store in E.164 format (e.g., "+919876543210")
  whatsappEnabled Boolean    @default(false)
  emailVerified   DateTime?
  image           String?
  wakatimeApiKey  String?
  githubApiKey    String?
  linkedinApiKey  String?
  twitterApiKey   String?
  accounts        Account[]
  sessions        Session[]
  // Add your app-specific fields here
  habits          Habit[]
  tasks           Task[]
  todos           Todo[]
  wakaTimeStats   WakaTime[]
  workoutPlans    WorkoutPlan[]

  height      Float?
  weight      Float?
  fitnessGoal String? // "Bulking", "Cutting", "Strength"
  experience  String? // "Beginner", "Intermediate"

  incomePlans   IncomePlan[]    // ✅ NEW
  projectPlans  ProjectPlan[]   // ✅ NEW
  careerPlans   CareerPlan[]    // ✅ NEW
  userProfile   UserProfile?    // ✅ NEW
  feedbacks     UserFeedback[]  // ✅ NEW
  replanLogs    ReplanLog[]
}

model Habit {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  name        String
  description String?
  category    String?
  frequency   String   @default("daily") // daily, weekly
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs HabitLog[]
}

model HabitLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  habitId   String   @db.ObjectId
  date      DateTime
  completed Boolean  @default(true)
  createdAt DateTime @default(now())

  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)
}

model Task {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  title       String
  description String?
  category    String? // Code, Fitness, Freelance, Growth, etc.
  startDate   DateTime
  endDate     DateTime
  status      String   @default("pending") // pending, in-progress, completed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Todo {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  userId           String    @db.ObjectId
  task             String
  category         String?
  reminderTime     DateTime?
  extraTime        Int?
  whatsappNotified Boolean   @default(false)
  completed        Boolean   @default(false)
  completedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WakaTime {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @db.ObjectId
  date       DateTime
  totalTime  String
  projects   Json
  languages  Json
  categories Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model SystemConfig {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model WorkoutPlan {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  userId     String   @db.ObjectId
  goal       String // e.g., "Full Body Hypertrophy"
  weekNumber Int // To track Week 1, Week 2, etc.
  startDate  DateTime
  endDate    DateTime
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  workouts Workout[]
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Workout {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  planId      String    @db.ObjectId
  dayOfWeek   String // "Monday"
  focus       String // "Chest + Triceps"
  isCompleted Boolean   @default(false)
  completedAt DateTime?

  exercises   WorkoutExercise[]
  workoutPlan WorkoutPlan       @relation(fields: [planId], references: [id], onDelete: Cascade)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
}

model WorkoutExercise {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  workoutId   String   @db.ObjectId
  exerciseId   String
  name        String   // e.g., "Bench Press"
  sets        Int
  reps        Int
  weight      Float?   // The weight assigned by the AI
  gifUrl      String?  // From ExerciseDB
  notes       String?  // Form tips from the Researcher Agent
  completedSets Int    @default(0)
  
  workout     Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
}

model UserProfile {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  userId        String   @unique @db.ObjectId
  profession    String?
  skills        String[]
  monthlyIncome Float?
  fitnessLevel  String?
  primaryGoal   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model IncomePlan {
  id           String       @id @default(auto()) @map("_id") @db.ObjectId
  userId       String       @db.ObjectId
  goal         String
  targetAmount Float
  strategy     String
  startDate    DateTime
  endDate      DateTime
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  weeks IncomeWeek[]
  user  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model IncomeWeek {
  id             String       @id @default(auto()) @map("_id") @db.ObjectId
  planId         String       @db.ObjectId
  weekNumber     Int
  focus          String
  targetEarnings Float
  createdAt      DateTime     @default(now())

  tasks IncomeTask[]
  plan  IncomePlan   @relation(fields: [planId], references: [id], onDelete: Cascade)
}

model IncomeTask {
  id              String     @id @default(auto()) @map("_id") @db.ObjectId
  weekId          String     @db.ObjectId
  day             Int
  action          String
  platform        String?
  timeRequired    Float
  expectedOutcome String
  priority        Int
  isCompleted     Boolean    @default(false)
  completedAt     DateTime?
  createdAt       DateTime   @default(now())

  week IncomeWeek @relation(fields: [weekId], references: [id], onDelete: Cascade)
}

model ProjectPlan {
  id             String         @id @default(auto()) @map("_id") @db.ObjectId
  userId         String         @db.ObjectId
  projectName    String
  description    String
  techStack      String
  totalDays      Int
  mvpDescription String
  startDate      DateTime
  endDate        DateTime
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  phases ProjectPhase[]
  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ProjectPhase {
  id          String        @id @default(auto()) @map("_id") @db.ObjectId
  planId      String        @db.ObjectId
  phaseNumber Int
  phaseName   String
  startDay    Int
  endDay      Int
  createdAt   DateTime      @default(now())

  tasks ProjectTask[]
  plan  ProjectPlan   @relation(fields: [planId], references: [id], onDelete: Cascade)
}

model ProjectTask {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  phaseId        String    @db.ObjectId
  dayNumber      Int
  title          String
  description    String
  estimatedHours Float
  type           String    // "frontend" | "backend" | "design" | "testing" | "deployment"
  isCompleted    Boolean   @default(false)
  completedAt    DateTime?
  createdAt      DateTime  @default(now())

  phase ProjectPhase @relation(fields: [phaseId], references: [id], onDelete: Cascade)
}

model UserFeedback {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  userId              String   @db.ObjectId
  feedback            String
  sentiment           String   // "positive" | "neutral" | "negative" | "overwhelmed" | "motivated"
  planType            String   // "gym" | "income" | "project" | "career" | "general"
  suggestedAdjustment String
  createdAt           DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ReplanLog {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  userId      String   @db.ObjectId
  domain      String
  reason      String
  adjustments String   // Store as JSON string
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}


model CareerPlan {
  id             String         @id @default(auto()) @map("_id") @db.ObjectId
  userId         String         @db.ObjectId
  currentRole    String
  targetRole     String
  targetCompany  String?
  timelineWeeks  Int
  strategy       String
  startDate      DateTime
  endDate        DateTime
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  milestones CareerMilestone[]
  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model CareerMilestone {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  planId      String    @db.ObjectId
  weekNumber  Int
  title       String
  description String
  tasks       String[]  // Simple string array for career tasks
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  plan CareerPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
}